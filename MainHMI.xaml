                                <ListBox x:Name="DatabaseTagList" Height="180" SelectionChanged="DatabaseTagList_SelectionChanged">
                                    <ListBox.ItemTemplate><DataTemplate><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Name}"/><TextBlock Text="{Binding Address}" Foreground="{StaticResource MutedBrush}" FontSize="10"/></StackPanel></Grid></DataTemplate></ListBox.ItemTemplate>
                                </ListBox>
                                <CheckBox x:Name="DatabaseTagEnabledCheck" Content="Salva questa tag" Foreground="{StaticResource TextBrush}" Margin="0,10,0,0"/>
                                <TextBlock Text="Modalità salvataggio" Style="{StaticResource FieldLabel}"/><ComboBox x:Name="DatabaseLoggingModeCombo"/>
                                <TextBlock Text="Intervallo temporale (ms)" Style="{StaticResource FieldLabel}"/><TextBox x:Name="DatabaseLoggingIntervalBox"/>
                                <Button Content="Salva impostazioni tag" Style="{StaticResource AccentButton}" Margin="0,10,0,12" Click="SaveDatabaseTagLogging_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="RIDONDANZA">
                        <Grid Margin="8">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="165"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <StackPanel>
                                <CheckBox x:Name="RedundancyEnabledCheck" Content="Abilita ridondanza pannelli" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="0,8"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Ritardo failover (ms)" Style="{StaticResource FieldLabel}"/><TextBox x:Name="RedundancyDelayBox"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="Controllo rete (ms)" Style="{StaticResource FieldLabel}"/><TextBox x:Name="RedundancyHealthBox"/></StackPanel>
                                </Grid>
                                <Button Content="Salva impostazioni" Style="{StaticResource AccentButton}" Margin="0,9,0,9" Click="SaveRedundancySettings_Click"/>
                            </StackPanel>
                            <ListBox x:Name="RedundantPanelList" Grid.Row="1" SelectionChanged="RedundantPanelList_SelectionChanged">
                                <ListBox.ItemTemplate><DataTemplate><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Host}" Foreground="{StaticResource MutedBrush}" FontSize="10"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding Priority}" Foreground="{StaticResource AccentBrush}" FontSize="18" Margin="8,0"/></Grid></DataTemplate></ListBox.ItemTemplate>
                            </ListBox>
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="PANNELLO RIDONDANTE" Style="{StaticResource SectionLabel}" Margin="0,10,0,3"/>
                                    <TextBlock Text="Nome pannello" Style="{StaticResource FieldLabel}"/><TextBox x:Name="RedundantPanelNameBox"/>
                                    <TextBlock Text="Indirizzo IP / host" Style="{StaticResource FieldLabel}"/><TextBox x:Name="RedundantPanelHostBox"/>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="Porta SignalR" Style="{StaticResource FieldLabel}"/><TextBox x:Name="RedundantPanelPortBox"/></StackPanel>
                                        <StackPanel Grid.Column="2"><TextBlock Text="Priorità" Style="{StaticResource FieldLabel}"/><TextBox x:Name="RedundantPanelPriorityBox"/></StackPanel>
                                    </Grid>
                                    <CheckBox x:Name="RedundantPanelLocalCheck" Content="Questo è il pannello locale" Foreground="{StaticResource TextBrush}" Margin="0,12,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <Button Content="Nuovo" Style="{StaticResource ToolbarButton}" Click="NewRedundantPanel_Click"/>
                                        <Button Content="Salva" Style="{StaticResource AccentButton}" Click="SaveRedundantPanel_Click"/>
                                        <Button Content="Elimina" Style="{StaticResource ToolbarButton}" Click="DeleteRedundantPanel_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border x:Name="BottomBar" Grid.Row="2" Background="#080D12" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ConnectionDot" Width="7" Height="7" Fill="#6B7B8C" Margin="0,0,7,0"/>
                    <TextBlock x:Name="StatusText" Text="Modalità sviluppo · progetto pronto" Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="HMI Studio · formato progetto v5" Foreground="#5F7081" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
