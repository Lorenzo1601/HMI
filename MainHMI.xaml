<Window x:Class="HMI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HMI Studio" Height="900" Width="1500" MinHeight="720" MinWidth="1180"
        WindowStartupLocation="CenterScreen" Background="#0B1118"
        Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#111A24"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#16212D"/>
        <SolidColorBrush x:Key="LineBrush" Color="#263545"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E8EEF5"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#8FA0B3"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#28C2B8"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#227CFF"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D151E"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0D151E"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="DropBorder" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1" CornerRadius="5" Padding="10,7">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="22"/></Grid.ColumnDefinitions>
                                                <ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center" TextElement.Foreground="{StaticResource TextBrush}"/>
                                                <TextBlock Grid.Column="1" Text="⌄" Foreground="{StaticResource AccentBrush}" FontSize="15"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="DropBorder" Property="BorderBrush" Value="#3C566E"/></Trigger>
                                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="DropBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" PopupAnimation="Fade" Focusable="False">
                                <Border Background="#111B25" BorderBrush="#355066" BorderThickness="1" CornerRadius="5"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" Margin="0,3,0,0" Padding="4">
                                    <ScrollViewer MaxHeight="280" CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ComboItemBorder" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ComboItemBorder" Property="Background" Value="#1E3445"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="ComboItemBorder" Property="Background" Value="#174341"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#0D151E"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="#0D151E"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0D151E"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#253545"/>
            <Setter Property="RowBackground" Value="#101923"/>
            <Setter Property="AlternatingRowBackground" Value="#141F2A"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1B2A38"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#334354"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#253545"/>
            <Setter Property="Padding" Value="7,5"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#253545"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="9,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="{StaticResource TextBrush}"/></Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="#16232E"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ColorSwatchButton" TargetType="Button">
            <Setter Property="Width" Value="25"/><Setter Property="Height" Value="25"/><Setter Property="Margin" Value="2"/>
            <Setter Property="BorderBrush" Value="#607284"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="9,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1B2A38"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#173A3B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="#182431"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#213142"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#061514"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="ToolboxButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="MinHeight" Value="55"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="InspectorExpanderHeader" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="HeaderBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Path x:Name="HeaderArrow" Data="M 1,1 L 5,5 L 1,9" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6"
                                      Width="6" Height="10" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" TextElement.FontSize="11"
                                                  TextElement.FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="HeaderBorder" Property="Background" Value="#1B2A38"/></Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="HeaderArrow" Property="Data" Value="M 1,1 L 5,5 L 9,1"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="#355066"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PropertySectionExpander" TargetType="Expander">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderSite" Content="{TemplateBinding Header}" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Style="{StaticResource InspectorExpanderHeader}"/>
                            <Border x:Name="ExpandSite" BorderBrush="{StaticResource LineBrush}" BorderThickness="1,0,1,1"
                                    CornerRadius="0,0,5,5" Padding="10,6,10,9" Background="#0F1821">
                                <ContentPresenter ContentSource="Content"/>
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False"><Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DrawingBrush x:Key="GridBrush" TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute" Viewbox="0,0,20,20" ViewboxUnits="Absolute">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="#101821">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#1D2A37" Thickness="0.5"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="20,0" EndPoint="20,20"/>
                            <LineGeometry StartPoint="0,20" EndPoint="20,20"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopBarRow" Height="68"/>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="BottomBarRow" Height="30"/>
        </Grid.RowDefinitions>

        <Border x:Name="TopBar" Grid.Row="0" Background="#0E161F" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" CornerRadius="8" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="H" Foreground="#071817" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="HMI STUDIO" FontWeight="Bold" FontSize="15"/>
                        <TextBlock Text="Designer industriale" Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel x:Name="ProjectCommandsPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Nuovo" Style="{StaticResource ToolbarButton}" Click="NewProject_Click"/>
                    <Button Content="Apri" Style="{StaticResource ToolbarButton}" Click="OpenProject_Click"/>
                    <Button Content="Salva" Style="{StaticResource ToolbarButton}" Click="SaveProject_Click"/>
                    <Button Content="Esporta runtime" Style="{StaticResource ToolbarButton}" Click="ExportRuntime_Click"/>
                </StackPanel>
                <StackPanel x:Name="ModeCommandsPanel" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="DesignModeButton" Content="●  SVILUPPO" Style="{StaticResource AccentButton}" Click="EnterDesignMode_Click"/>
                    <Button x:Name="RuntimeModeButton" Content="▶  RUNTIME" Style="{StaticResource ToolbarButton}" Click="EnterRuntimeMode_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="6" VerticalAlignment="Center">
                    <TextBlock x:Name="ProjectNameText" Text="Nuovo progetto" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="ProjectPathText" Text="Non salvato" Foreground="{StaticResource MutedBrush}" FontSize="10" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" x:Name="MainWorkspace">
            <Grid.ColumnDefinitions>
                <!-- Colonna SINISTRA (ora contiene Pagine): usa le misure più piccole -->
                <ColumnDefinition x:Name="LeftSidebarColumn" Width="248" MinWidth="210" MaxWidth="420"/>

                <ColumnDefinition x:Name="LeftSidebarRailColumn" Width="28"/>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition x:Name="RightSidebarRailColumn" Width="28"/>

                <!-- Colonna DESTRA (ora contiene Proprietà): usa le misure più grandi -->
                <ColumnDefinition x:Name="RightSidebarColumn" Width="330" MinWidth="280" MaxWidth="560"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="DesignerSidebar" Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="190"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Text="PAGINE" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                        <UniformGrid Grid.Row="1" Columns="5">
                            <Button Content="＋" Style="{StaticResource ToolbarButton}" Margin="2" Padding="6,3" Click="AddPage_Click" ToolTip="Aggiungi pagina"/>
                            <Button Content="−" Style="{StaticResource ToolbarButton}" Margin="2" Padding="6,3" Click="DeletePage_Click" ToolTip="Elimina pagina"/>
                            <Button Content="＋▰" Style="{StaticResource ToolbarButton}" Margin="2" Padding="6,3" Click="AddPageFolder_Click" ToolTip="Aggiungi cartella"/>
                            <Button Content="✎▰" Style="{StaticResource ToolbarButton}" Margin="2" Padding="6,3" Click="RenamePageFolder_Click" ToolTip="Rinomina cartella"/>
                            <Button Content="−▰" Style="{StaticResource ToolbarButton}" Margin="2" Padding="6,3" Click="DeletePageFolder_Click" ToolTip="Elimina cartella"/>
                        </UniformGrid>
                    </Grid>
                    <TreeView x:Name="PageTree" Grid.Row="1" Background="Transparent" Foreground="{StaticResource TextBrush}" BorderThickness="0"
                              SelectedItemChanged="PageTree_SelectedItemChanged" PreviewMouseLeftButtonDown="PageTree_PreviewMouseLeftButtonDown"
                              MouseDoubleClick="PageTree_MouseDoubleClick"/>
                    <Border Grid.Row="2" Background="{StaticResource LineBrush}" Margin="0,8"/>
                    <TextBlock Grid.Row="3" Text="OGGETTI" Style="{StaticResource SectionLabel}" Margin="0,14,0,8"/>
                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <UniformGrid Columns="2" VerticalAlignment="Top">
                            <Button Content="Tt&#x0a;Testo" Tag="Label" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="▣&#x0a;Pulsante" Tag="Button" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="123&#x0a;Valore" Tag="ValueDisplay" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="●&#x0a;Spia" Tag="Indicator" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="⌨&#x0a;Campo input" Tag="NumericInput" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="→&#x0a;Navigazione" Tag="Navigation" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="R&#x0a;Ricette" Tag="RecipeManager" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="!&#x0a;Allarmi" Tag="AlarmViewer" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="◷&#x0a;Storico allarmi" Tag="AlarmHistoryViewer" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="▤&#x0a;Storico dati" Tag="DataHistoryViewer" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="⌁&#x0a;Grafico" Tag="TrendChart" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="▧&#x0a;Immagine" Tag="Image" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="↗&#x0a;Popup toggle" Tag="PopupButton" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="⏻&#x0a;Esci runtime" Tag="RuntimeExit" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="👤&#x0a;Gestione utenti" Tag="UserManager" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="⇥&#x0a;Login" Tag="LoginButton" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                            <Button Content="⇤&#x0a;Logout" Tag="LogoutButton" Style="{StaticResource ToolboxButton}" Click="AddWidget_Click"/>
                        </UniformGrid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid x:Name="LeftSidebarRail" Grid.Column="1" Background="#0D151E" Panel.ZIndex="3">
                <GridSplitter x:Name="LeftSidebarSplitter" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="#263545" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True" KeyboardIncrement="16" Cursor="SizeWE" DragCompleted="SidebarSplitter_DragCompleted"
                              ToolTip="Ridimensiona pannello Proprietà" AutomationProperties.Name="Ridimensiona pannello Proprietà"/>
                <Button x:Name="ToggleLeftSidebarButton" Content="‹" Style="{StaticResource ToolbarButton}" Width="24" Height="34"
                        Padding="0" Margin="2,8,2,0" VerticalAlignment="Top" Panel.ZIndex="2" Click="ToggleLeftSidebar_Click"
                        ToolTip="Nascondi pannello Proprietà" AutomationProperties.Name="Nascondi pannello Proprietà"/>
            </Grid>

            <Grid Grid.Column="2" Background="#090E14">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="WorkspaceToolbarRow" Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border x:Name="DesignerToolbar" Grid.Row="0" Background="#0F1821" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
                    <Grid Margin="14,0">
                        <Grid.ColumnDefinitions><ColumnDefinition MinWidth="110"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Grid ClipToBounds="True" Margin="0,0,10,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
                            <TextBlock x:Name="CurrentPageText" Text="Panoramica" FontWeight="SemiBold" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            <TextBlock x:Name="CurrentPageSizeText" Grid.Column="1" Text="  /  Area 1280 × 720" Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        </Grid>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,4,0">
                                <TextBlock Text="ALLINEA" Foreground="{StaticResource MutedBrush}" FontSize="9"/>
                                <TextBlock Text="Ctrl+clic" Foreground="#65788B" FontSize="8"/>
                            </StackPanel>
                            <Button x:Name="AlignLeftButton" Content="⇤" Tag="SelectionLeft" Style="{StaticResource ToolbarButton}" Margin="1,0" Padding="7,3" Click="AlignWidgets_Click" ToolTip="Allinea a sinistra rispetto all'oggetto primario"/>
                            <Button x:Name="AlignCenterXButton" Content="↔" Tag="SelectionCenterX" Style="{StaticResource ToolbarButton}" Margin="1,0" Padding="7,3" Click="AlignWidgets_Click" ToolTip="Allinea i centri orizzontali"/>
                            <Button x:Name="AlignRightButton" Content="⇥" Tag="SelectionRight" Style="{StaticResource ToolbarButton}" Margin="1,0" Padding="7,3" Click="AlignWidgets_Click" ToolTip="Allinea a destra rispetto all'oggetto primario"/>
                            <Button x:Name="AlignTopButton" Content="⤒" Tag="SelectionTop" Style="{StaticResource ToolbarButton}" Margin="1,0" Padding="7,3" Click="AlignWidgets_Click" ToolTip="Allinea in alto"/>
