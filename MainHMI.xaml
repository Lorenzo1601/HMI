                                                    <Button Background="#101820" Tag="#101820" Style="{StaticResource ColorSwatchButton}" Click="AnimationDefaultForegroundSwatch_Click"/>
                                                    <Button Background="#227CFF" Tag="#227CFF" Style="{StaticResource ColorSwatchButton}" Click="AnimationDefaultForegroundSwatch_Click"/>
