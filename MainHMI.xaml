                                                <Button Background="#227CFF" Tag="#227CFF" Style="{StaticResource ColorSwatchButton}" Click="AnimationDefaultBackgroundSwatch_Click"/>
                                                <Button Background="#F1B24A" Tag="#F1B24A" Style="{StaticResource ColorSwatchButton}" Click="AnimationDefaultBackgroundSwatch_Click"/>
